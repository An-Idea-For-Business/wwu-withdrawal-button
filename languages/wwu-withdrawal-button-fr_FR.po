msgstr "Impossible de marquer la demande comme traitée — la commande n'a pas pu être chargée."

#: src/Admin/RequestsDashboard.php:378
msgid "Acknowledgement email resent."
msgstr "E-mail d'accusé de réception renvoyé."

#: src/Admin/RequestsDashboard.php:379
